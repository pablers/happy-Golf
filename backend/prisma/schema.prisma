// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  profile      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  rounds       Round[]
}

model Round {
  id               String           @id @default(cuid())
  date             DateTime
  courseId         String
  courseName       String
  userId           String
  user             User             @relation(fields: [userId], references: [id])
  practiceTime     PracticeTime
  weather          WeatherCondition
  wind             WindCondition
  roundType        RoundType
  startingHole     Int              @default(1)
  scorecard        HoleScore[]
  emotionalState   Json?
  reviewQuestions  Json?
  totalStrokes     Int?
  totalPutts       Int?
  toPar            Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model HoleScore {
  id         String  @id @default(cuid())
  hole       Int
  par        Int
  strokeIndex Int
  strokes    Int?
  putts      Int?
  comment    String?
  fairwayHit Boolean?
  round      Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId    String
}

enum RoundType {
  FRONT
  BACK
  FULL
}

enum PracticeTime {
  NONE
  MIN_5
  MIN_5_15
  MIN_15_PLUS
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  RAINY
  VARIABLE
}

enum WindCondition {
  NONE
  LIGHT
  MODERATE
  STRONG
}
