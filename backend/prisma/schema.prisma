// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  rounds    Round[]
}

model Profile {
  id                String      @id @default(cuid())
  name              String
  trainingObjective String?
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String      @unique
  hcpHistory        HcpRecord[]
  favoriteCourses   GolfCourse[] @relation("FavoriteCourses")
}

model HcpRecord {
  id        String   @id @default(cuid())
  date      DateTime
  hcp       Float
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
}

model Round {
  id           String    @id @default(cuid())
  date         DateTime
  roundType    RoundType
  practiceTime PracticeTime
  weather      WeatherCondition
  wind         WindCondition
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  course       GolfCourse @relation(fields: [courseId], references: [id])
  courseId     String
  scores       HoleScore[]
  answers      Json
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model GolfCourse {
  id           String  @id @default(cuid())
  name         String
  address      String?
  municipality String?
  province     String?
  region       String?
  phone        String?
  email        String?
  url          String?
  latitude     String?
  longitude    String?
  rounds       Round[]
  favoritedBy  Profile[] @relation("FavoriteCourses")
}

model HoleScore {
  id         String  @id @default(cuid())
  hole       Int
  par        Int
  strokeIndex Int
  strokes    Int?
  putts      Int?
  comment    String?
  fairwayHit Boolean?
  round      Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId    String
}

enum RoundType {
  FRONT
  BACK
  FULL
}

enum PracticeTime {
  NONE
  MIN_5
  MIN_5_15
  MIN_15_PLUS
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  RAINY
  VARIABLE
}

enum WindCondition {
  NONE
  LIGHT
  MODERATE
  STRONG
}