// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//- ENUMS

enum RoundType {
  FULL
  FRONT_NINE
  BACK_NINE
  PRACTICE
}

enum Weather {
  SUNNY
  CLOUDY
  VARIABLE
  RAINY
}

enum Wind {
  NONE
  LIGHT
  MODERATE
  STRONG
  HIGHER // Note: "higher" might be better represented as a variant of STRONG
}

enum TurfCondition {
  CORRECT
  LONGISH
  LONG
}

enum GreenSpeed {
  SLOW
  MEDIUM
  FAST
}

enum PhysicalState {
  GOOD
  BIT_TIRED
  TIRED
  DISCOMFORT
}

enum MentalState {
  FOCUSED
  NEUTRAL
  DISTRACTED
  FRUSTRATED
}

enum PracticeTime {
  NONE
  MIN_5
  MIN_5_15
  MIN_15_PLUS
}

//- MODELS

model User {
  id                Int          @id @default(autoincrement())
  email             String       @unique
  passwordHash      String
  name              String
  favoriteCourseIds String[]
  trainingObjective String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  hcpHistory        HcpRecord[]
  rounds            Round[]
}

model HcpRecord {
  id        Int      @id @default(autoincrement())
  date      DateTime
  hcp       Float
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
}

model Round {
  id              String        @id
  date            DateTime
  user            User          @relation(fields: [userId], references: [id])
  userId          Int
  userHcp         Float
  courseId        String
  roundType       RoundType
  practiceTime    PracticeTime
  initialWeather  Weather
  initialWind     Wind
  turfCondition   TurfCondition
  greenSpeed      GreenSpeed
  physicalState   PhysicalState
  mentalState     MentalState
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  holes           Hole[]
}

model Hole {
  id         Int      @id @default(autoincrement())
  round      Round    @relation(fields: [roundId], references: [id])
  roundId    String
  holeNumber Int
  strokes    Int
  putts      Int
  comment    String?
  fairwayHit Boolean?

  @@unique([roundId, holeNumber])
}
