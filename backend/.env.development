# Backend Environment Variables for Development

# JWT secret key for signing tokens
# In a real production environment, this should be a long, complex, and securely stored string.
JWT_SECRET=a-very-secret-key-for-development

# The origin allowed to make requests to this backend.
# This should be the URL where the frontend application is running.
CORS_ORIGIN=http://localhost:5173

# Port for the backend server
PORT=3001